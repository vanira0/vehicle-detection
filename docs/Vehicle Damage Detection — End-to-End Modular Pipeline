### Component 6: Inference Pipeline & Orchestrator

#### [NEW] [pipeline.py](file:///D:/vehicle-detection/src/inference/pipeline.py)

End-to-end 3-stage pipeline:

```python
class VehicleDamagePipeline:
    def __init__(self, gatekeeper_ckpt, damage_ckpt, parts_ckpt, config):
        self.gatekeeper = self._load_model("gatekeeper", gatekeeper_ckpt)
        self.damage_model = self._load_model("damage", damage_ckpt)
        self.parts_model = self._load_model("parts", parts_ckpt)
        self.orchestrator = Orchestrator(config.inference.iou_threshold)

    def __call__(self, image_path: str) -> dict:
        image = self.preprocess(image_path)

        # Stage 1: Gatekeeper
        gate_result = self.gatekeeper.predict(image)
        if not gate_result["is_damaged"]:
            return {"status": "no_damage", "confidence": gate_result["confidence"]}

        # Stage 2 & 3: Run in parallel (or sequential)
        damage_masks = self.damage_model.predict(image)
        part_masks = self.parts_model.predict(image)

        # Stage 4: Orchestrate
        report = self.orchestrator.map_damage_to_parts(damage_masks, part_masks)
        return {"status": "damaged", "findings": report}
```

