### Component 4: Training Engine

#### [NEW] [trainer.py](file:///D:/vehicle-detection/src/training/trainer.py)

A **model-agnostic** training loop. It doesn't import any specific model — it receives one via the registry.

```python
class Trainer:
    def __init__(self, config, model_wrapper, train_loader, val_loader, callbacks=None):
        self.config = config
        self.model = model_wrapper.build(config.model).to(self.device)
        self.optimizer = OptimizerFactory.create(config.training.optimizer, self.model)
        self.scheduler = SchedulerFactory.create(config.training.scheduler, self.optimizer)
        self.scaler = torch.cuda.amp.GradScaler(enabled=config.training.amp)
        self.callbacks = callbacks or []

    def train_one_epoch(self, epoch):
        self.model.train()
        for batch_idx, (images, targets) in enumerate(self.train_loader):
            with torch.cuda.amp.autocast(enabled=self.config.training.amp):
                loss_dict = self.model_wrapper.compute_loss(self.model, images, targets)
                total_loss = sum(loss_dict.values()) / self.config.training.gradient_accumulation

            self.scaler.scale(total_loss).backward()

            if (batch_idx + 1) % self.config.training.gradient_accumulation == 0:
                self.scaler.step(self.optimizer)
                self.scaler.update()
                self.optimizer.zero_grad()

        self.scheduler.step()
        return loss_dict

    def fit(self):
        for epoch in range(self.config.training.epochs):
            train_losses = self.train_one_epoch(epoch)
            val_metrics = self.evaluate(epoch)
            for cb in self.callbacks:
                cb.on_epoch_end(epoch, train_losses, val_metrics, self.model)
```

#### [NEW] [optimizers.py](file:///D:/vehicle-detection/src/training/optimizers.py)

Factory that creates optimizers by name from config:

```python
class OptimizerFactory:
    @staticmethod
    def create(config, model):
        params = [p for p in model.parameters() if p.requires_grad]
        if config.name == "sgd":
            return torch.optim.SGD(params, lr=config.lr, momentum=config.momentum, weight_decay=config.weight_decay)
        elif config.name == "adam":
            return torch.optim.Adam(params, lr=config.lr, weight_decay=config.weight_decay)
        elif config.name == "adamw":
            return torch.optim.AdamW(params, lr=config.lr, weight_decay=config.weight_decay)
```

